# .env.example — Copy this file to .env and fill in your real values
# cp .env.example .env

# Supabase Configuration
# Find these in your Supabase Dashboard under Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# Stripe Configuration
# Find these in your Stripe Dashboard under Developers > API keys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# Stripe Webhook Secret
# Get this from running: stripe listen --forward-to localhost:5000/api/webhooks/stripe
# Or from Stripe Dashboard > Developers > Webhooks after creating an endpoint
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
